# PostgreSQL connection — consumed by the app, the postgres image, and the Makefile.
# Production: point DATABASE_URL at the managed/prod cluster; rotate POSTGRES_* secrets.
DATABASE_URL=postgresql://user:password@db:5432/gv-db?sslmode=disable
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=gv-db
# Name of the test database (Makefile composes TEST_DB_URL from this + POSTGRES_*)
TEST_DB=gv-db-tests

# HTTP server
PORT=8080
# IANA timezone for date arithmetic (defaults to Europe/Madrid in code if unset)
TIMEZONE=Europe/Madrid

# --- REPLACE every value below for any non-local environment ---
# Login passwords (the app authenticates against these)
PASSWORD=Private123..
SEMIPRIVATE_PASSWORD=Semiprivate123..
# Random secret used to sign JWTs — generate with: openssl rand -hex 32
JWT_SECRET=secret
# Base32 secret used for TOTP — generate with: openssl rand -base32 20
TOTP_SECRET=secret
